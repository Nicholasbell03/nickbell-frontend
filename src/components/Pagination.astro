---
interface Props {
  currentPage: number;
  lastPage: number;
  basePath: string;
}

const { currentPage, lastPage, basePath } = Astro.props;

if (lastPage <= 1) return;

const prevHref = currentPage > 1
  ? currentPage === 2 ? basePath : `${basePath}?page=${currentPage - 1}`
  : null;
const nextHref = currentPage < lastPage
  ? `${basePath}?page=${currentPage + 1}`
  : null;
---

<div class="flex items-center justify-center gap-4 mt-12">
  {prevHref ? (
    <a
      href={prevHref}
      class="inline-flex items-center justify-center gap-1 whitespace-nowrap rounded-md text-sm font-medium h-9 px-3 border border-emerald-500/20 hover:border-emerald-500/50 hover:bg-emerald-500/5 transition-colors"
    >
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Previous
    </a>
  ) : (
    <span class="inline-flex items-center justify-center gap-1 whitespace-nowrap rounded-md text-sm font-medium h-9 px-3 border border-emerald-500/20 opacity-50 cursor-not-allowed">
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Previous
    </span>
  )}

  <span class="text-sm text-muted-foreground">
    Page {currentPage} of {lastPage}
  </span>

  {nextHref ? (
    <a
      href={nextHref}
      class="inline-flex items-center justify-center gap-1 whitespace-nowrap rounded-md text-sm font-medium h-9 px-3 border border-emerald-500/20 hover:border-emerald-500/50 hover:bg-emerald-500/5 transition-colors"
    >
      Next
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </a>
  ) : (
    <span class="inline-flex items-center justify-center gap-1 whitespace-nowrap rounded-md text-sm font-medium h-9 px-3 border border-emerald-500/20 opacity-50 cursor-not-allowed">
      Next
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </span>
  )}
</div>
