---
import Layout from '@/layouts/Layout.astro';

Astro.response.status = 404;
---

<Layout title="Page not found | Nicholas Bell" description="The page you're looking for doesn't exist.">
  <div class="max-w-2xl mx-auto px-4 py-32 text-center space-y-6">
    <p class="text-6xl font-bold text-emerald-500">404</p>
    <h1 class="text-2xl font-semibold">Page not found</h1>
    <p class="text-muted-foreground">
      The page you're looking for doesn't exist or may have been removed.
    </p>
    <div class="flex justify-center gap-4 pt-4">
      <a
        href="/"
        class="px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium transition-colors"
      >
        Go home
      </a>
      <a
        href="/blog"
        class="px-5 py-2.5 rounded-lg border border-emerald-500/20 hover:border-emerald-500/40 text-sm font-medium transition-colors"
      >
        Browse the blog
      </a>
    </div>
  </div>
</Layout>
