---
import Layout from '@/layouts/Layout.astro';
import Pagination from '@/components/Pagination.astro';
import { fetchApi } from '@/lib/api';
import { setCdnCache } from '@/lib/cache';
import { formatDistanceToNow } from 'date-fns';
import { safeHostname, stripHtml } from '@/lib/utils';
import type { ShareSummary, SourceType } from '@/types/share';
import type { PaginatedResponse } from '@/types/blog';

const page = Number(Astro.url.searchParams.get('page')) || 1;

let shares: ShareSummary[] = [];
let meta: PaginatedResponse<ShareSummary>['meta'] | null = null;

try {
  const res = await fetchApi<PaginatedResponse<ShareSummary>>(`/api/v1/shares?page=${page}`);
  shares = res.data;
  meta = res.meta;
} catch (err) {
  // Will render error state below
}

// CDN cache: 1 hour fresh, 1 day stale-while-revalidate (skipped on API failure)
setCdnCache(Astro.response, meta, { sMaxAge: 3600, swr: 86400 });

const SOURCE_BADGE: Record<SourceType, { label: string }> = {
  webpage: { label: 'Web' },
  youtube: { label: 'YouTube' },
  x_post: { label: 'X / Twitter' },
  linkedin: { label: 'LinkedIn' },
};
---

<Layout
  title="Shares | Nicholas Bell"
  description="Curated links, videos, and posts worth sharing — with personal commentary"
>
  <div class="py-16 md:py-24 px-4">
    <div class="container mx-auto max-w-7xl">
      <div class="text-center space-y-4 mb-12">
        <h1 class="text-4xl md:text-5xl font-bold">Shares</h1>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Curated links, videos, and posts worth sharing — with personal commentary
        </p>
      </div>

      {shares.length === 0 && (
        <div class="text-center space-y-4">
          <p class="text-muted-foreground">No shares found.</p>
        </div>
      )}

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {shares.map((share, index) => (
          <a href={`/shares/${share.slug}`} class="block">
            <div
              class="group rounded-lg border border-emerald-500/20 bg-card text-card-foreground shadow-sm hover:shadow-xl hover:shadow-emerald-500/10 transition-all duration-300 overflow-hidden h-full cursor-pointer flex flex-col"
              style={`animation: fadeIn 0.5s ease-out ${index * 0.05}s both`}
            >
              <div class="relative h-40 overflow-hidden bg-muted">
                {share.image_url ? (
                  <img
                    src={share.image_url}
                    alt={share.title ?? ''}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-emerald-500/10 to-emerald-500/5 flex items-center justify-center">
                    {share.source_type === 'youtube' && (
                      <svg class="h-14 w-14 text-emerald-800" viewBox="0 0 576 512" fill="currentColor"><path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"/></svg>
                    )}
                    {share.source_type === 'x_post' && (
                      <svg class="h-14 w-14 text-emerald-800" viewBox="0 0 512 512" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg>
                    )}
                    {share.source_type === 'linkedin' && (
                      <svg class="h-14 w-14 text-emerald-800" viewBox="0 0 448 512" fill="currentColor"><path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zM384.3 416h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/></svg>
                    )}
                    {share.source_type === 'webpage' && (
                      <svg class="h-14 w-14 text-emerald-800" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                    )}
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent" />
              </div>
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <span class="inline-flex items-center gap-1 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-emerald-400 px-2.5 py-0.5 text-xs font-semibold">
                    {share.source_type === 'youtube' && (
                      <svg class="h-3 w-3" viewBox="0 0 576 512" fill="currentColor"><path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"/></svg>
                    )}
                    {share.source_type === 'x_post' && (
                      <svg class="h-3 w-3" viewBox="0 0 512 512" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg>
                    )}
                    {share.source_type === 'linkedin' && (
                      <svg class="h-3 w-3" viewBox="0 0 448 512" fill="currentColor"><path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zM384.3 416h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/></svg>
                    )}
                    {share.source_type === 'webpage' && (
                      <svg class="h-3 w-3" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                    )}
                    {SOURCE_BADGE[share.source_type].label}
                  </span>
                  {share.author && (
                    <span class="text-sm text-muted-foreground">{share.author}</span>
                  )}
                </div>
                <h2 class="text-lg font-semibold leading-none tracking-tight group-hover:text-emerald-400 transition-colors mb-2">
                  {share.title ?? safeHostname(share.url)}
                </h2>
                {(share.summary || share.commentary) && (
                  <p class:list={['text-sm text-muted-foreground mb-4', !share.summary && 'line-clamp-3']}>
                    {share.summary ?? stripHtml(share.commentary ?? '')}
                  </p>
                )}
                <div class="mt-auto flex items-center justify-between text-sm">
                  <span class="text-muted-foreground">
                    {formatDistanceToNow(new Date(share.created_at), { addSuffix: true })}
                  </span>
                  <span class="text-emerald-400 group-hover:text-emerald-300 flex items-center gap-1">
                    View
                    <svg class="h-3 w-3 group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      {meta && (
        <Pagination
          currentPage={meta.current_page}
          lastPage={meta.last_page}
          basePath="/shares"
        />
      )}
    </div>
  </div>
</Layout>
