---
import Layout from '@/layouts/Layout.astro';
import { fetchApi } from '@/lib/api';
import { sanitizeCmsHtml } from '@/lib/sanitize';
import { getItemPath } from '@/lib/contentType';
import type { Project } from '@/types/project';
import type { RelatedContentResponse } from '@/types/related';

const { slug } = Astro.params;
const token = Astro.url.searchParams.get('token');

// Fetch project and related content in parallel
const endpoint = token ? `/api/v1/projects/preview/${slug}` : `/api/v1/projects/${slug}`;
const headers: Record<string, string> = token ? { 'X-Preview-Token': token } : {};

let project: Project | null = null;
let relatedData: RelatedContentResponse['data'] | null = null;

try {
  const [projectRes, relatedRes] = await Promise.all([
    fetchApi<{ data: Project }>(endpoint, { headers }),
    fetchApi<RelatedContentResponse>(`/api/v1/projects/${slug}/related`).catch(() => null),
  ]);
  project = projectRes.data;
  relatedData = relatedRes?.data ?? null;
} catch {
  return Astro.redirect('/projects');
}

if (!project) return Astro.redirect('/projects');

const sanitizedLongDescription = project.long_description
  ? sanitizeCmsHtml(project.long_description)
  : '';

// CDN cache: 7 days fresh, 30 days stale-while-revalidate (skip for previews)
if (!token) {
  Astro.response.headers.set(
    'Netlify-CDN-Cache-Control',
    'public, s-maxage=604800, stale-while-revalidate=2592000'
  );
}
---

<Layout
  title={`${project.title} | Nicholas Bell`}
  description={project.description ?? ''}
  image={project.featured_image ?? undefined}
  type="article"
  publishedTime={project.published_at}
>
  <div class="py-16 md:py-24 px-4">
    {token && (
      <div class="fixed top-0 left-0 right-0 z-50 bg-amber-500 text-amber-950 py-2 px-4 text-center font-medium">
        <svg class="inline-block h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
        Preview Mode — This content is not published
      </div>
    )}
    <div class:list={['container mx-auto max-w-4xl', token && 'mt-8']}>
      <a href="/projects" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 mb-8 group hover:bg-accent hover:text-accent-foreground transition-colors">
        <svg class="h-4 w-4 group-hover:-translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back
      </a>

      <article class="space-y-8">
        {project.featured_image && (
          <div class="rounded-lg overflow-hidden border border-emerald-500/20">
            <img src={project.featured_image} alt={project.title} class="w-full max-h-[400px] object-contain" />
          </div>
        )}

        <div class="space-y-4">
          <h1 class="text-4xl md:text-5xl font-bold leading-tight">{project.title}</h1>
          {project.description && <p class="text-xl text-muted-foreground">{project.description}</p>}
        </div>

        <div class="flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <span class="inline-flex items-center rounded-full border border-emerald-500/20 bg-emerald-500/10 text-emerald-400 text-sm px-3 py-1 font-semibold">
              {tech}
            </span>
          ))}
        </div>

        {(project.project_url || project.github_url) && (
          <div class="flex gap-4">
            {project.project_url && (
              <a
                href={project.project_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 bg-emerald-500 text-white hover:bg-emerald-600 transition-colors"
              >
                <!-- ExternalLink icon -->
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                Live Demo
              </a>
            )}
            {project.github_url && (
              <a
                href={project.github_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
              >
                <!-- GitHub icon -->
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                View Code
              </a>
            )}
          </div>
        )}

        {sanitizedLongDescription && (
          <div class="border-t border-emerald-500/20 pt-8">
            <div
              class="prose prose-invert prose-lg max-w-none prose-headings:text-foreground prose-a:text-emerald-400 prose-a:no-underline prose-a:hover:underline prose-strong:text-foreground prose-code:text-emerald-300 prose-pre:bg-slate-900 prose-pre:border prose-pre:border-emerald-500/20 prose-img:rounded-lg"
              set:html={sanitizedLongDescription}
            />
          </div>
        )}

        {relatedData?.related && relatedData.related.length > 0 && (
          <div class="border-t border-emerald-500/20 pt-8 space-y-4">
            <h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider">
              You might also like
            </h3>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {relatedData.related.map((item, index) => (
                <a href={getItemPath(item)} class="block">
                  <div
                    class="group rounded-lg border border-emerald-500/20 bg-card shadow-sm hover:shadow-xl hover:shadow-emerald-500/10 transition-all duration-300 overflow-hidden h-full cursor-pointer flex flex-col"
                    style={`animation: fadeIn 0.5s ease-out ${index * 0.1}s both`}
                  >
                    <div class="relative h-32 overflow-hidden bg-muted">
                      {item.image ? (
                        <img
                          src={item.image}
                          alt={item.title}
                          loading="lazy"
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        />
                      ) : (
                        <div class="w-full h-full bg-gradient-to-br from-emerald-500/10 to-emerald-500/5 flex items-center justify-center">
                          <svg class="h-10 w-10 text-emerald-800" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
                        </div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent" />
                      <span class="absolute top-2 right-2 bg-background/80 text-emerald-400 border border-emerald-500/20 text-xs rounded-full px-2 py-0.5 font-medium capitalize">
                        {item.type}
                      </span>
                    </div>
                    <div class="p-4 flex-1">
                      <h4 class="text-sm font-semibold group-hover:text-emerald-400 transition-colors line-clamp-2">
                        {item.title}
                      </h4>
                      {item.description && (
                        <p class="text-xs text-muted-foreground line-clamp-2 mt-1">
                          {item.description}
                        </p>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="border-t border-emerald-500/20 pt-8 flex justify-between">
          <a href="/projects" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground group transition-colors">
            <svg class="h-4 w-4 group-hover:-translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            All Projects
          </a>
          {relatedData?.next && (
            <a
              href={getItemPath(relatedData.next)}
              class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground group transition-colors"
              title={relatedData.next.title}
            >
              Next Project
              <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
        </div>
      </article>
    </div>
  </div>
</Layout>
