---
import Layout from '@/layouts/Layout.astro';
import Pagination from '@/components/Pagination.astro';
import { fetchApi } from '@/lib/api';
import { formatDistanceToNow } from 'date-fns';
import type { BlogSummary, PaginatedResponse } from '@/types/blog';

const page = Number(Astro.url.searchParams.get('page')) || 1;

let posts: BlogSummary[] = [];
let meta: PaginatedResponse<BlogSummary>['meta'] | null = null;

try {
  const res = await fetchApi<PaginatedResponse<BlogSummary>>(`/api/v1/blogs?page=${page}`);
  posts = res.data;
  meta = res.meta;
} catch (err) {
  // Will render error state below
}

// CDN cache: 1 hour fresh, 1 day stale-while-revalidate
Astro.response.headers.set(
  'Netlify-CDN-Cache-Control',
  'public, s-maxage=3600, stale-while-revalidate=86400'
);
---

<Layout
  title="Blog | Nicholas Bell"
  description="Thoughts on web development, AI integration, software architecture, and lessons learned from building real-world applications"
>
  <div class="py-16 md:py-24 px-4">
    <div class="container mx-auto max-w-7xl">
      <div class="text-center space-y-4 mb-12">
        <h1 class="text-4xl md:text-5xl font-bold">All Posts</h1>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Thoughts on web development, AI integration, software architecture, and lessons learned from building real-world applications
        </p>
      </div>

      {posts.length === 0 && (
        <div class="text-center space-y-4">
          <p class="text-muted-foreground">No posts found.</p>
        </div>
      )}

      <div class="space-y-6">
        {posts.map((post, index) => (
          <a href={`/blog/${post.slug}`} class="block">
            <div
              class="group rounded-lg border border-emerald-500/20 bg-card text-card-foreground shadow-sm hover:shadow-xl hover:shadow-emerald-500/10 transition-all duration-300 cursor-pointer"
              style={`animation: fadeIn 0.5s ease-out ${index * 0.1}s both`}
            >
              <div class="flex flex-col md:flex-row">
                <div class="md:w-64 lg:w-80 shrink-0">
                  {post.featured_image ? (
                    <img
                      src={post.featured_image}
                      alt={post.title}
                      loading="lazy"
                      class="w-full h-48 object-cover rounded-t-lg md:rounded-l-lg md:rounded-tr-none"
                    />
                  ) : (
                    <div class="w-full h-48 min-h-[160px] bg-slate-800/50 rounded-t-lg md:rounded-l-lg md:rounded-tr-none flex flex-col items-center justify-center gap-3 border-r border-emerald-500/10">
                      <svg class="h-10 w-10 text-emerald-500/40" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                      <span class="text-xs text-muted-foreground/50 uppercase tracking-widest">Article</span>
                    </div>
                  )}
                </div>
                <div class="flex flex-col flex-1 p-6">
                  <div class="flex items-center gap-4 text-sm text-muted-foreground mb-3">
                    <div class="flex items-center gap-1">
                      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                      {formatDistanceToNow(new Date(post.published_at), { addSuffix: true })}
                    </div>
                    <div class="flex items-center gap-1">
                      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {post.read_time} min
                    </div>
                  </div>
                  <h2 class="text-xl font-semibold leading-none tracking-tight group-hover:text-emerald-400 transition-colors mb-2">
                    {post.title}
                  </h2>
                  <p class="text-sm text-muted-foreground line-clamp-2 mb-4">
                    {post.excerpt}
                  </p>
                  <div class="mt-auto text-sm text-emerald-400 group-hover:text-emerald-300 flex items-center gap-2">
                    Read More
                    <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      {meta && (
        <Pagination
          currentPage={meta.current_page}
          lastPage={meta.last_page}
          basePath="/blog"
        />
      )}
    </div>
  </div>
</Layout>
