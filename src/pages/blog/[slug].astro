---
import Layout from '@/layouts/Layout.astro';
import RelatedContentCard from '@/components/RelatedContentCard.astro';
import { fetchApi } from '@/lib/api';
import { setCdnCache } from '@/lib/cache';
import { sanitizeCmsHtml } from '@/lib/sanitize';
import { getItemPath } from '@/lib/contentType';
import { format } from 'date-fns';
import type { Blog } from '@/types/blog';
import type { RelatedContentResponse } from '@/types/related';

const { slug } = Astro.params;
const token = Astro.url.searchParams.get('token');

// Fetch blog and related content in parallel
const endpoint = token ? `/api/v1/blogs/preview/${slug}` : `/api/v1/blogs/${slug}`;
const headers: Record<string, string> = token ? { 'X-Preview-Token': token } : {};

let post: Blog | null = null;
let relatedData: RelatedContentResponse['data'] | null = null;

try {
  const [blogRes, relatedRes] = await Promise.all([
    fetchApi<{ data: Blog }>(endpoint, { headers }),
    fetchApi<RelatedContentResponse>(`/api/v1/blogs/${slug}/related`).catch(() => null),
  ]);
  post = blogRes.data;
  relatedData = relatedRes?.data ?? null;
} catch {
  return Astro.redirect('/blog');
}

if (!post) return Astro.redirect('/blog');

const sanitizedContent = sanitizeCmsHtml(post.content);

// CDN cache: 7 days fresh, 30 days stale-while-revalidate (skipped for previews)
setCdnCache(Astro.response, token ? null : post, { sMaxAge: 604800, swr: 2592000 });
---

<Layout
  title={`${post.title} | Nicholas Bell`}
  description={post.meta_description ?? post.excerpt ?? ''}
  image={post.featured_image ?? undefined}
  type="article"
  publishedTime={post.published_at}
>
  <div class="py-16 md:py-24 px-4">
    {token && (
      <div class="fixed top-0 left-0 right-0 z-50 bg-amber-500 text-amber-950 py-2 px-4 text-center font-medium">
        <svg class="inline-block h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
        Preview Mode — This content is not published
      </div>
    )}
    <div class:list={['container mx-auto max-w-4xl', token && 'mt-8']}>
      <a href="/blog" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 mb-8 group hover:bg-accent hover:text-accent-foreground transition-colors">
        <svg class="h-4 w-4 group-hover:-translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back
      </a>

      <article class="space-y-8">
        <div class="space-y-4">
          <div class="flex items-center gap-4 text-sm text-muted-foreground">
            <div class="flex items-center gap-1">
              <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              {format(new Date(post.published_at), 'MMMM d, yyyy')}
            </div>
            <div class="flex items-center gap-1">
              <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {post.read_time} min read
            </div>
          </div>

          <h1 class="text-4xl md:text-5xl font-bold leading-tight">{post.title}</h1>
          {post.excerpt && <p class="text-xl text-muted-foreground">{post.excerpt}</p>}
        </div>

        {post.featured_image && (
          <div class="rounded-lg overflow-hidden border border-emerald-500/20">
            <img src={post.featured_image} alt={post.title} class="w-full max-h-[400px] object-contain" />
          </div>
        )}

        <div class="border-t border-emerald-500/20 pt-8">
          <div
            class="prose prose-invert prose-lg max-w-none prose-headings:text-foreground prose-a:text-emerald-400 prose-a:no-underline prose-a:hover:underline prose-strong:text-foreground prose-code:text-emerald-300 prose-pre:bg-slate-900 prose-pre:border prose-pre:border-emerald-500/20 prose-img:rounded-lg"
            set:html={sanitizedContent}
          />
        </div>

        {relatedData?.related && relatedData.related.length > 0 && (
          <div class="border-t border-emerald-500/20 pt-8 space-y-4">
            <h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider">
              You might also like
            </h3>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {relatedData.related.map((item, index) => (
                <RelatedContentCard item={item} index={index} />
              ))}
            </div>
          </div>
        )}

        <div class="border-t border-emerald-500/20 pt-8 flex justify-between">
          <a href="/blog" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground group transition-colors">
            <svg class="h-4 w-4 group-hover:-translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            All Posts
          </a>
          {relatedData?.next && (
            <a
              href={getItemPath(relatedData.next)}
              class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-10 px-4 py-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground group transition-colors"
              title={relatedData.next.title}
            >
              Next Post
              <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
        </div>
      </article>
    </div>
  </div>
</Layout>
